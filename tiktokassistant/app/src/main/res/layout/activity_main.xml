<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="抖音助手"
        android:textSize="16sp" />

    <RadioGroup
        android:id="@+id/rgDirection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <RadioButton
            android:id="@+id/rbUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="向上滑"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbDown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="向下滑"
            android:layout_marginStart="16dp" />
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="间隔（秒）"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/editIntervalSec"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如 10"
        android:inputType="number"
        android:text="10" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="时长（小时，>0 启用；填 0 表示不限制）"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/editDurationHour"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如 1"
        android:inputType="numberDecimal"
        android:text="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="次数（>0 启用；填 0 表示不限制）"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/editCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="例如 30"
        android:inputType="number"
        android:text="30" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="开始" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="停止"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnFloating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="开启悬浮球（点击可开始/停止滑动）" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hint_desc"
        android:textSize="12sp"
        android:layout_marginTop="16dp" />
</LinearLayout>

